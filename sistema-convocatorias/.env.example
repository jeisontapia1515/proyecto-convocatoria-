# ===================================
# CONFIGURACIÓN DE BASE DE DATOS
# ===================================
DATABASE_PATH=database/convocatorias.db

# ===================================
# CONFIGURACIÓN DE EMAIL
# ===================================
# Para Gmail:
# 1. Activa verificación en 2 pasos
# 2. Genera una contraseña de aplicación en: https://myaccount.google.com/apppasswords
# 3. Usa esa contraseña aquí

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=tu_email@gmail.com
SMTP_PASSWORD=tu_contraseña_de_aplicación
EMAIL_FROM=tu_email@gmail.com

# Destinatarios (separados por coma)
EMAIL_TO=decanatura@universidad.edu.co,investigacion@universidad.edu.co

# ===================================
# CONFIGURACIÓN DE SCRAPING
# ===================================
# Intervalo entre ejecuciones de scraping (en horas)
SCRAPING_INTERVAL=6

# Número máximo de workers concurrentes
MAX_WORKERS=5

# Timeout para requests (en segundos)
REQUEST_TIMEOUT=30

# User-Agent para requests
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ===================================
# CONFIGURACIÓN DE FILTRADO
# ===================================
# Umbral mínimo de relevancia (0-100)
MIN_RELEVANCE_SCORE=30

# Peso para coincidencia de palabras clave (0-1)
KEYWORD_WEIGHT=0.4

# Peso para similitud semántica (0-1)
SEMANTIC_WEIGHT=0.3

# Peso para análisis de entidades (0-1)
ENTITY_WEIGHT=0.2

# Peso para frescura de la convocatoria (0-1)
FRESHNESS_WEIGHT=0.1

# ===================================
# CONFIGURACIÓN DE NOTIFICACIONES
# ===================================
# Enviar notificación inmediata para convocatorias de alta relevancia
INSTANT_NOTIFICATION_THRESHOLD=80

# Día para reporte semanal (monday, tuesday, etc.)
WEEKLY_REPORT_DAY=monday

# Hora para reporte semanal (formato 24h)
WEEKLY_REPORT_HOUR=9

# ===================================
# CONFIGURACIÓN DE LOGS
# ===================================
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ===================================
# CONFIGURACIÓN DEL SERVIDOR
# ===================================
HOST=0.0.0.0
PORT=8000
DEBUG=False

# ===================================
# CONFIGURACIÓN DE SEGURIDAD
# ===================================
SECRET_KEY=cambia_esto_por_una_clave_segura_aleatoria
# Genera una clave con: python -c "import secrets; print(secrets.token_urlsafe(32))"

# ===================================
# CONFIGURACIÓN DE PROXY (Opcional)
# ===================================
# Descomenta si necesitas usar proxy
# HTTP_PROXY=http://proxy.universidad.edu.co:8080
# HTTPS_PROXY=https://proxy.universidad.edu.co:8080

# ===================================
# CONFIGURACIÓN DE SELENIUM (Opcional)
# ===================================
# Usar headless mode para Selenium
SELENIUM_HEADLESS=true

# Path al driver de Chrome (dejar vacío para auto-descarga)
CHROME_DRIVER_PATH=
